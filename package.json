    "lz-string": "^1.5.0",
    "moment": "^2.30.1",
    "obs-websocket-js": "^5.0.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-draggable-plus": "^0.6.1",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.3.0",
