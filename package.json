{
  "name": "ff14-overlay-vue",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "tsc": "vue-tsc --noEmit | grep -v 'cactbot/'",
    "build": "vp run submodule && vp run generate && vp build",
    "preview": "vp preview",
    "generate:role-action-categories": "jiti scripts/roleActionCategoryByJob.ts",
    "generate:action-upgrade-steps": "jiti scripts/actionUpgradeStepsBake.ts",
    "generate:action-min-level": "jiti scripts/actionMinLevelBake.ts",
    "generate:action-meta-lite": "jiti scripts/actionMetaBake.ts",
    "generate:dd-normalize": "jiti scripts/ddNormalize.ts",
    "generate:dd-vulnerabilities": "jiti scripts/ddVulnerabilitiesBake.ts --only-undefined-to-bool",
    "submodule": "git submodule update --remote && jiti scripts/patch.ts",
    "generate": "jiti scripts/all.ts && vp fmt src/resources/generated",
    "generate:blacksmith-skills": "node scripts/generateBlacksmithSkills.cjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.3.0",
    "@vueuse/head": "^2.0.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.2",
    "github-markdown-css": "^5.9.0",
    "idb": "^8.0.3",
    "json5": "^2.2.3",
    "lz-string": "^1.5.0",
    "moment": "^2.30.1",
    "obs-websocket-js": "^5.0.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-draggable-plus": "^0.6.1",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.4.6",
    "vue-lazyload": "^3.0.0",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@johnsoncodehk/html2pug": "^1.0.0",
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@types/fs-extra": "^11.0.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "csv-parser": "^3.2.1",
    "csv-writer": "^1.6.0",
    "fs-extra": "^11.3.5",
    "iconv-lite": "^0.7.2",
    "jiti": "^2.7.0",
    "opencc-js": "^1.3.1",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-md": "^0.22.5",
    "vite-plugin-pages": "^0.33.3",
    "vite-plus": "0.2.1",
    "vue-tsc": "^3.3.5"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.17.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher"
    ]
  }
