    "@types/fs-extra": "^11.0.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-sfc": "^3.5.30",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "fs-extra": "^11.3.4",
    "iconv-lite": "^0.7.2",
    "jiti": "^2.6.1",
