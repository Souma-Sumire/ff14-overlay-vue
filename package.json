    "unplugin-vue-components": "^31.0.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-md": "^0.22.5",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-sass-dts": "^1.3.35",
    "vite-plus": "latest",
